rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    // 'plan' field is server-only — clients cannot elevate their own subscription
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
        && (!('plan' in request.resource.data) || request.resource.data.plan == 'free');
      allow update: if request.auth != null && request.auth.uid == userId
        && !('plan' in request.resource.data.diff(resource.data).affectedKeys());

      // Memory subcollection (users/{uid}/memory/context)
      match /memory/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Daily cache subcollection (users/{uid}/cache/dailyNews)
      match /cache/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Briefing generation jobs (users/{uid}/briefingJobs/current).
      // The client submits jobs (status 'queued') and reads progress; the
      // worker function writes results via the Admin SDK (bypasses rules).
      match /briefingJobs/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Episodes: users can only access their own
    match /episodes/{episodeId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // Source connections: user-scoped
    match /source_connections/{docId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }
  }
}
